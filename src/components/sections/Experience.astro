---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import silhouetteImg from '../../assets/nicholai-fully-body-sillhouette-night.avif';
import closeupPortrait from '../../assets/nicholai-closeup-lowerface.avif';

interface Props {
	sectionTitle: string;
	sectionSubtitle: string;
	sectionLabel: string;
	description: string;
	entries: Array<{
		systemId: string;
		status: string;
		dates: string;
		company: string;
		role: string;
		tags?: string[];
		description: string;
		achievements?: Array<{
			label: string;
			text: string;
		}>;
		link?: {
			url: string;
			text: string;
		};
	}>;
}

const { sectionLabel, entries } = Astro.props;

// Editorial image mapping per entry (by index)
const entryImages: ImageMetadata[] = [silhouetteImg, closeupPortrait];
---

<div id="experience" class="bg-[var(--theme-bg-primary)] border-t border-[var(--theme-border-primary)]">
	<!-- Minimal intro -->
	<div class="container mx-auto px-6 lg:px-8 py-20 lg:py-28">
		<div class="flex items-center gap-3">
			<div class="w-1.5 h-1.5 bg-brand-accent animate-pulse"></div>
			<span class="font-mono text-[10px] uppercase tracking-[0.25em] text-brand-accent">{sectionLabel}</span>
		</div>
	</div>

	<!-- Full-bleed editorial chapters -->
	{entries.map((entry, index) => {
		const img = entryImages[index % entryImages.length];
		const textRight = index % 2 === 0; // alternate anchor side for editorial rhythm

		return (
			<section class:list={['group/chapter relative w-full overflow-hidden', index > 0 ? 'border-t border-[var(--theme-border-primary)]' : '']}>
				<!-- Full-bleed background image -->
				<div class="absolute inset-0 z-0">
					<Picture
						src={img}
						formats={['avif', 'webp']}
						widths={[1024, 1600, 2400]}
						sizes="100vw"
						alt={`${entry.company} — ${entry.role}`}
						class="w-full h-full object-cover grayscale-[0.25] group-hover/chapter:grayscale-0 opacity-70 group-hover/chapter:opacity-90 transition-all duration-700 ease-out"
						loading={index === 0 ? 'eager' : 'lazy'}
					/>
					<!-- Single soft vignette: gentle fade on the text side only (long falloff, no hard edge) -->
					<div
						class:list={['absolute inset-0 pointer-events-none', textRight ? 'lg:bg-gradient-to-l' : 'lg:bg-gradient-to-r']}
						style="background: linear-gradient(to bottom, var(--theme-bg-primary) 0%, rgba(0,0,0,0) 22%, rgba(0,0,0,0) 78%, var(--theme-bg-primary) 100%);"
					></div>
					<div
						class:list={['absolute inset-0 pointer-events-none hidden lg:block', textRight ? 'bg-gradient-to-l' : 'bg-gradient-to-r']}
						style="background: linear-gradient(to bottom, var(--theme-bg-primary), rgba(0,0,0,0) 22%, rgba(0,0,0,0) 78%, var(--theme-bg-primary)), linear-gradient(to right, var(--theme-bg-primary), rgba(0,0,0,0));"
					></div>
					<!-- Subtle scanline texture (industrial DNA) -->
					<div class="absolute inset-0 pointer-events-none opacity-[0.06] bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,112,0.06))] bg-[length:100%_2px,3px_100%] group-hover/chapter:opacity-0 transition-opacity duration-700"></div>
				</div>

				<!-- Overlaid editorial text -->
				<div class="relative z-10 container mx-auto px-6 lg:px-8 py-32 lg:py-44 min-h-[80vh] lg:min-h-[90vh] flex items-center">
					<div class:list={[
						'w-full grid grid-cols-1 lg:grid-cols-12 gap-8',
						textRight ? '' : ''
					]}>
						<div class:list={['lg:col-span-6 flex flex-col justify-center', textRight ? 'lg:col-start-7' : 'lg:col-span-6']}>

							<!-- Meta: dates · role -->
							<p class="text-sm text-[var(--theme-text-muted)] mb-4">
								<span class="text-brand-accent">{entry.dates}</span>
								<span> · {entry.role}</span>
							</p>

							<!-- Title -->
							<h3 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-[var(--theme-text-primary)] leading-[1.05]">
								{entry.company}
							</h3>

							<!-- Statement -->
							<p class="text-lg text-[var(--theme-text-secondary)] leading-relaxed mt-6 max-w-md">
								{entry.description}
							</p>

							<!-- Link -->
							{entry.link && (
								<a
									href={entry.link.url}
									target="_blank"
									rel="noopener noreferrer"
									class="mt-8 inline-flex items-center gap-2 text-sm text-brand-accent hover:gap-3 transition-all duration-300 w-fit"
								>
									<span>{entry.link.text}</span>
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M5 12h14M12 5l7 7-7 7" />
									</svg>
								</a>
							)}
						</div>
					</div>
				</div>
			</section>
		);
	})}
</div>
